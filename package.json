{
  "name": "solid-mosaic-component",
  "version": "0.1.0",
  "description": "A SolidJS Tiling Window Manager",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/MuNeNICK/solid-mosaic"
  },
  "main": "lib/index.js",
  "style": "solid-mosaic-component.css",
  "type": "commonjs",
  "typings": "lib/index.d.ts",
  "keywords": [
    "ui",
    "solid",
    "solidjs",
    "component",
    "typescript",
    "tiling-window-manager",
    "window-manager"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "npm-run-all clean -lp build:**",
    "build:ts": "tsc -p tsconfig-build.json",
    "build:less": "lessc --autoprefix=defaults styles/index.less solid-mosaic-component.css",
    "clean": "rm -rf lib/",
    "prettier:run": "prettier 'styles/*.less' '*.md' '{,.}*.yml'",
    "test": "npm-run-all build -lp test:**",
    "test:unit": "vitest run",
    "test:format": "npm run prettier:run -- --list-different",
    "fix": "npm-run-all -lp fix:**",
    "fix:format": "npm run prettier:run -- --write"
  },
  "dependencies": {
    "classnames": "^2.3.2",
    "immutability-helper": "^3.1.1",
    "lodash": "^4.17.21",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/lodash": "^4.14.191",
    "@types/node": "^25.3.3",
    "@types/uuid": "^9.0.0",
    "less": "^3.13.1",
    "less-plugin-autoprefix": "^2.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.8.4",
    "solid-js": "^1.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "solid-js": ">=1.7"
  }
}
